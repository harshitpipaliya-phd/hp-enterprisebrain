{
  "name": "@hpbrain/api",
  "version": "0.1.0",
  "private": true,
  "description": "HP Enterprise Brain — Foundation API (Sprint 1). Auth, tenancy, Neo4j repository.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "graph:migrate": "tsx src/cli/apply-graph-migrations.ts",
    "seed": "tsx src/cli/seed.ts",
    "seed:teacher": "tsx src/cli/seed-teacher-capabilities.ts",
    "seed:student": "tsx src/cli/seed-student-capabilities.ts",
    "seed:healthcare-workforce": "tsx src/cli/seed-healthcare-workforce-capabilities.ts"
  },
  "dependencies": {
    "@hpbrain/contracts": "*",
    "@hpbrain/database": "*",
    "@hpbrain/events": "*",
    "connect-timeout": "^1.9.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "neo4j-driver": "^5.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/connect-timeout": "^1.9.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
